{
  "models": {
    "providers": {
      "google": {
        "apiKey": "${GEMINI_API_KEY}",
        "api": "google-generative-ai",
        "baseUrl": "https://generativelanguage.googleapis.com/v1beta",
        "models": [
          { "id": "gemini-2.5-flash", "name": "gemini-2.5-flash" },
          { "id": "gemini-2.5-pro", "name": "gemini-2.5-pro" }
        ]
      }
    }
  },

  "env": {
    "OPENCLAW_ENV": "PROD"
  },

  "tools": {
    "loopDetection": {
      "enabled": true,
      "warningThreshold": 10,
      "criticalThreshold": 20,
      "globalCircuitBreakerThreshold": 30
    },
    "exec": {
      "applyPatch": { "enabled": true }
    },
    "web": {
      "search": { "enabled": true },
      "fetch": { "enabled": true }
    },
    "elevated": {
      "enabled": false
    }
  },

  "agents": {
    "defaults": {
      "workspace": "~/.openclaw/workspace",
      "heartbeat": { "every": "2h" },
      "compaction": {
        "reserveTokensFloor": 20000,
        "memoryFlush": {
          "enabled": true,
          "softThresholdTokens": 4000,
          "systemPrompt": "Session nearing compaction. Store durable memories now.",
          "prompt": "Write any lasting notes to memory/today.md; reply with NO_REPLY if nothing to store."
        }
      }
    },

    "list": [
      {
        "id": "triage",
        "default": true,
        "workspace": "~/.openclaw/workspace",
        "model": "google/gemini-2.5-flash",
        "identity": { "name": "Claw", "emoji": "📋", "theme": "task triage and routing" },
        "tools": {
          "profile": "minimal",
          "allow": ["read", "group:memory", "web_search", "web_fetch"],
          "deny": ["exec", "write", "edit", "apply_patch"]
        },
        "sandbox": { "mode": "off" }
      },
      {
        "id": "coder",
        "workspace": "~/.openclaw/workspace",
        "model": "google/gemini-2.5-pro",
        "identity": { "name": "Coder", "emoji": "⚡", "theme": "code implementation" },
        "tools": {
          "profile": "coding",
          "allow": ["group:fs", "group:runtime", "group:memory", "web_fetch"],
          "deny": []
        },
        "sandbox": { "mode": "off" }
      },
      {
        "id": "debugger",
        "workspace": "~/.openclaw/workspace",
        "model": "google/gemini-2.5-pro",
        "identity": { "name": "Debugger", "emoji": "🔍", "theme": "debugging and investigation" },
        "tools": {
          "profile": "coding",
          "allow": ["read", "exec", "group:memory", "web_fetch"],
          "deny": ["write", "edit", "apply_patch"]
        },
        "sandbox": { "mode": "off" }
      },
      {
        "id": "security",
        "workspace": "~/.openclaw/workspace",
        "model": "google/gemini-2.5-pro",
        "identity": { "name": "Security", "emoji": "🛡️", "theme": "security review" },
        "tools": {
          "profile": "minimal",
          "allow": ["read", "group:memory"],
          "deny": ["exec", "write", "edit", "apply_patch"]
        },
        "sandbox": { "mode": "off" }
      },
      {
        "id": "tester",
        "workspace": "~/.openclaw/workspace",
        "model": "google/gemini-2.5-flash",
        "identity": { "name": "Tester", "emoji": "🧪", "theme": "testing and validation" },
        "tools": {
          "profile": "coding",
          "allow": ["read", "exec", "group:memory"],
          "deny": ["write", "edit", "apply_patch"]
        },
        "sandbox": { "mode": "off" }
      }
    ]
  },

  "channels": {
    "discord": {
      "enabled": true,
      "token": "${DISCORD_BOT_TOKEN}",

      "ackReaction": "⚡",

      "dmPolicy": "pairing",

      "guilds": {
        "*": {
          "requireMention": false
        }
      },

      "actions": {
        "reactions": true,
        "messages": true,
        "threads": true,
        "pins": true,
        "search": true,
        "memberInfo": true,
        "roleInfo": true,
        "channelInfo": true,
        "moderation": false
      },

      "execApprovals": {
        "enabled": true,
        "target": "channel",
        "sessionFilter": [],
        "cleanupAfterResolve": true
      },

      "ui": {
        "components": {
          "accentColor": "#5865F2"
        }
      }
    }
  },

  "bindings": [
    {
      "agentId": "triage",
      "match": { "channel": "discord" }
    }
  ],

  "messages": {
    "groupChat": {
      "mentionPatterns": ["@claw", "@openclaw", "@bot"]
    }
  },

  "gateway": {
    "mode": "local"
  }
}
