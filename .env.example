# ═══════════════════════════════════════════════════════════
# OpenClaw Bot Employee — Environment Variables
# Copy this file to ~/.openclaw/.env and fill in your values
# ═══════════════════════════════════════════════════════════

# ── LLM Provider (set at least ONE) ──────────────────────
# OpenClaw auto-detects which provider to use based on which
# API key is present. Set one, two, or all three — your choice.
#
# Gemini (cheapest):   https://aistudio.google.com/apikey
# OpenAI:              https://platform.openai.com/api-keys
# Anthropic:           https://console.anthropic.com/settings/keys

GEMINI_API_KEY=your-gemini-api-key
# OPENAI_API_KEY=sk-your-openai-key
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# ── GitHub ───────────────────────────────────────────────
GITHUB_TOKEN=ghp_your-github-pat

# ── Database (SQLite — no external service needed) ───────
# OPENCLAW_DB_PATH=~/.openclaw/bot.db

# ── Channels ─────────────────────────────────────────────
DISCORD_BOT_TOKEN=your-discord-bot-token
# TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# ── Sentry (optional) ───────────────────────────────────
# SENTRY_AUTH_TOKEN=your-sentry-auth-token
# SENTRY_ORG=your-sentry-org-slug

# ── Linear (optional) ───────────────────────────────────
# LINEAR_API_KEY=lin_api_your-linear-key

# ── Runtime ──────────────────────────────────────────────
OPENCLAW_ENV=PROD
